# job.env — sourced by the sbatch on each task. Sets a per-task scratch dir on local NVMe (/tmp),
# redirects all caches there, caps CPU threads (avoid oversubscription across tasks/node), and
# holds object-storage credentials + layout. Copy into <jobname>_coreweave/env/ and fill the keys.

# ---- per-task scratch dir on local NVMe ----
if [ -n "${SLURM_ARRAY_TASK_ID:-}" ]; then
    JOB_DIR="${SLURM_JOB_NAME:+${SLURM_JOB_NAME}_}${SLURM_ARRAY_JOB_ID}/${SLURM_ARRAY_TASK_ID}"
else
    JOB_DIR="${SLURM_JOB_NAME:+${SLURM_JOB_NAME}_}${SLURM_JOB_ID:-manual}"
fi
export JOB_DIR
export JOB_WORK_DIR="/tmp/${JOB_DIR}"

# ---- caches to local scratch (never /mnt/home) ----
export HF_HOME="${JOB_WORK_DIR}/.hf"
export TRANSFORMERS_CACHE="${JOB_WORK_DIR}/.hf"
export TORCH_HOME="${JOB_WORK_DIR}/.torch"
export XDG_CACHE_HOME="${JOB_WORK_DIR}/.cache"
export TRITON_CACHE_DIR="${JOB_WORK_DIR}/.triton"
export CUDA_CACHE_PATH="${JOB_WORK_DIR}/.nv"
export PYTHONPYCACHEPREFIX="${JOB_WORK_DIR}/.pycache"

# ---- run offline if all inputs are staged (drop these if the job needs the network) ----
export HF_HUB_OFFLINE=1
export TRANSFORMERS_OFFLINE=1
export TOKENIZERS_PARALLELISM=false

# ---- CPU thread caps: set ~= --cpus-per-task (else tasks oversubscribe the 128-core node) ----
export OMP_NUM_THREADS=${SLURM_CPUS_PER_TASK:-16}
export MKL_NUM_THREADS=${OMP_NUM_THREADS}
export OPENBLAS_NUM_THREADS=${OMP_NUM_THREADS}
export NUMEXPR_NUM_THREADS=${OMP_NUM_THREADS}

# ---- object storage (FILL THESE) ----
export AWS_ACCESS_KEY_ID=""          # CoreWeave console -> Object storage access keys
export AWS_SECRET_ACCESS_KEY=""

# ---- object storage layout (set BUCKET per cluster: brineylab-eu (B200) | brineylab-us-east (RTX)) ----
export BUCKET="brineylab-eu"
export S3="s3://${BUCKET}/${SLURM_JOB_USER:-$USER}/${SLURM_JOB_NAME:-job}"
export S5_ENDPOINT_INTERNAL="http://cwlota.com"     # from compute nodes
export S5_ENDPOINT_EXTERNAL="https://cwobject.com"  # from Scripps servers

mkdir -p "${JOB_WORK_DIR}"
